"use client";

import Link from "next/link";
import { useState, useEffect } from "react";

const API_URL =
  "https://calgary-compass-api.onrender.com";

function Detail({
  label,
  value,
}: {
  label: string;
  value: any;
}) {
  return (
    <div>
      <p className="text-xs uppercase tracking-wide text-gray-500 mb-1">
        {label}
      </p>

      <p className="text-gray-900">
        {value && String(value).trim()
          ? value
          : "—"}
      </p>
    </div>
  );
}

export default function CommunityFeedbackAdminPage() {

  const [votes, setVotes] =
    useState<any[]>([]);

  const [loading, setLoading] =
    useState(true);

  const [error, setError] =
    useState("");

  const [search, setSearch] =
    useState("");

  async function loadVotes() {

    setLoading(true);

    setError("");

    try {

      const response = await fetch(
        `${API_URL}/votes`
      );

      if (!response.ok) {
        throw new Error(
          "Failed request"
        );
      }

      const data =
        await response.json();

      setVotes(data);

    } catch (err) {

      console.error(err);

      setError(
        "Failed to load community feedback."
      );

    } finally {

      setLoading(false);

    }
  }

  useEffect(() => {

    loadVotes();

  }, []);

  const exportCsv = () => {

    const columns = [
      "id",
      "technology_name",
      "stakeholder",
      "financial_sustainability",
      "operational_excellence",
      "people_culture",
      "trusted_governance",
      "innovation_agility",
    ];

    const escape = (
      value: any
    ) => {

      const string =
        value === null ||
        value === undefined
          ? ""
          : String(value);

      return `"${string.replace(
        /"/g,
        '""'
      )}"`;
    };

    const rows = votes.map(
      (vote) =>
        columns
          .map((column) =>
            escape(vote[column])
          )
          .join(",")
    );

    const csv = [
      columns.join(","),
      ...rows,
    ].join("\n");

    const blob = new Blob(
      [csv],
      { type: "text/csv" }
    );

    const url =
      URL.createObjectURL(blob);

    const link =
      document.createElement("a");

    link.href = url;

    link.download =
      "community-feedback.csv";

    link.click();

    URL.revokeObjectURL(url);
  };

  const visibleVotes = votes
    .filter((vote) => {

      const query =
        search
          .trim()
          .toLowerCase();

      if (!query) {
        return true;
      }

      return (
        (
          vote.technology_name || ""
        )
          .toLowerCase()
          .includes(query) ||

        (
          vote.stakeholder || ""
        )
          .toLowerCase()
          .includes(query)
      );
    })
    .sort(
      (a, b) =>
        (b.id || 0) -
        (a.id || 0)
    );

  return (

    <main className="min-h-screen bg-gray-50 text-black">

      <div className="h-2 bg-red-700 w-full"></div>

      <div className="max-w-6xl mx-auto px-8 py-12">

        {/* NAVBAR */}

        <nav className="flex justify-between items-center mb-12">

          <Link
            href="/"
            className="text-2xl font-bold text-red-700"
          >

            Calgary Compass

          </Link>

          <div className="flex gap-6">

            <Link
              href="/admin"
              className="text-lg font-medium hover:text-red-700 transition"
            >

              Technologies Admin

            </Link>

            <Link
              href="/admin/applications"
              className="text-lg font-medium hover:text-red-700 transition"
            >

              Applications

            </Link>

          </div>

        </nav>

        {/* HEADER */}

        <div className="flex flex-wrap justify-between items-center gap-4 mb-8">

          <div>

            <h1 className="text-4xl font-bold text-red-700">

              Community Feedback

            </h1>

            <p className="text-gray-600 mt-1">

              {votes.length} total submissions

              {search.trim() &&
                ` · ${visibleVotes.length} matching`}

            </p>

          </div>

          <div className="flex gap-3">

            <button
              onClick={loadVotes}
              disabled={loading}
              className="
                border-2
                border-red-700
                text-red-700
                px-4
                py-2
                rounded-xl
                font-semibold
                hover:bg-red-700
                hover:text-white
                transition
                disabled:opacity-60
              "
            >

              {loading
                ? "Refreshing…"
                : "Refresh"}

            </button>

            <button
              onClick={exportCsv}
              disabled={
                votes.length === 0
              }
              className="
                bg-red-700
                text-white
                px-4
                py-2
                rounded-xl
                font-semibold
                hover:bg-red-800
                transition
                disabled:opacity-60
              "
            >

              Export CSV

            </button>

          </div>

        </div>

        {/* SEARCH */}

        <input
          type="text"
          value={search}
          onChange={(e) =>
            setSearch(
              e.target.value
            )
          }
          placeholder="Search by technology or stakeholder..."
          className="
            w-full
            border
            border-gray-300
            rounded-xl
            px-4
            py-3
            mb-8
            focus:outline-none
            focus:ring-2
            focus:ring-red-700
            focus:border-red-700
            transition
          "
        />

        {/* ERROR */}

        {error && (

          <p className="text-red-700 font-medium mb-6">

            {error}

          </p>

        )}

        {/* CONTENT */}

        {loading &&
        votes.length === 0 ? (

          <div className="bg-white border border-gray-200 rounded-2xl p-10 text-center text-gray-600 shadow-sm">

            Loading community feedback...

          </div>

        ) : visibleVotes.length === 0 ? (

          <div className="bg-white border border-gray-200 rounded-2xl p-10 text-center text-gray-600 shadow-sm">

            No feedback submissions found.

          </div>

        ) : (

          <div className="space-y-6">

            {visibleVotes.map(
              (vote) => (

                <div
                  key={vote.id}
                  className="
                    bg-white
                    border
                    border-gray-200
                    rounded-2xl
                    p-6
                    shadow-sm
                  "
                >

                  <div className="flex flex-wrap justify-between items-baseline gap-2 mb-5">

                    <h2 className="text-2xl font-bold text-red-700">

                      {
                        vote.technology_name
                      }

                    </h2>

                    <span className="text-sm text-gray-500">

                      #{vote.id}

                    </span>

                  </div>

                  <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">

                    <Detail
                      label="Stakeholder"
                      value={
                        vote.stakeholder
                      }
                    />

                    <Detail
                      label="Financial Sustainability"
                      value={
                        vote.financial_sustainability
                      }
                    />

                    <Detail
                      label="Operational Excellence"
                      value={
                        vote.operational_excellence
                      }
                    />

                    <Detail
                      label="People & Culture"
                      value={
                        vote.people_culture
                      }
                    />

                    <Detail
                      label="Trusted Governance"
                      value={
                        vote.trusted_governance
                      }
                    />

                    <Detail
                      label="Innovation & Agility"
                      value={
                        vote.innovation_agility
                      }
                    />

                  </div>

                </div>

              )
            )}

          </div>

        )}

      </div>

    </main>
  );
}
